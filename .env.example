NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ANTHROPIC_API_KEY=

# PDF (Chromium serverless en Vercel). Para local se ignora.
# https://github.com/Sparticuz/chromium/releases  (versión que matchea @sparticuz/chromium-min)
CHROMIUM_PACK_URL=https://github.com/Sparticuz/chromium/releases/download/v131.0.1/chromium-v131.0.1-pack.tar

# Base URL para que el route handler del PDF se llame a sí mismo en preview
# En Vercel: dejar vacío, usamos VERCEL_URL automáticamente.
# Local: http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
